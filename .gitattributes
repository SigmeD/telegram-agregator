# Нормализация line endings — критично для кроссплатформенной разработки
# (Windows dev → Linux VPS).

# По умолчанию — авто, Git сам решает по детекту бинарности
* text=auto

# Явно LF (unix) для всего, что запускается/интерпретируется на Linux
*.sh            text eol=lf
*.bash          text eol=lf
Dockerfile      text eol=lf
*.Dockerfile    text eol=lf
Makefile        text eol=lf
*.mk            text eol=lf
*.py            text eol=lf
*.toml          text eol=lf
*.yaml          text eol=lf
*.yml           text eol=lf
*.json          text eol=lf
*.js            text eol=lf
*.jsx           text eol=lf
*.ts            text eol=lf
*.tsx           text eol=lf
*.cjs           text eol=lf
*.mjs           text eol=lf
*.css           text eol=lf
*.html          text eol=lf
*.md            text eol=lf
*.sql           text eol=lf
*.conf          text eol=lf
.gitignore      text eol=lf
.gitattributes  text eol=lf
.editorconfig   text eol=lf
.env.example    text eol=lf
.dockerignore   text eol=lf

# Бинарники — не трогать
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.ico           binary
*.pdf           binary
*.zip           binary
*.tar.gz        binary
*.session       binary
*.session-journal binary
