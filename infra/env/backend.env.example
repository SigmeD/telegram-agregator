# -----------------------------------------------------------------------------
# infra/env/backend.env.example
#
# Copy to `infra/env/backend.env` (gitignored) and fill real values for local
# development on the dev VPS. Compose reads this via:
#   env_file: ../env/backend.env
#
# Production secrets MUST come from the platform (GitHub Secrets → CD pipeline
# writes a transient backend.env on the VPS); never commit a real backend.env.
# -----------------------------------------------------------------------------

# ---- Postgres -------------------------------------------------------------
POSTGRES_USER=tlg
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=tlg_dev

# ---- Telegram user-session (Telethon) -------------------------------------
# Real values from https://my.telegram.org. Phone in E.164.
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=00000000000000000000000000000000
TELEGRAM_PHONE=+10000000000
# Fernet 32-byte url-safe base64 key. Generate locally with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TELETHON_SESSION_KEY=replace-with-fernet-key

# ---- LLM providers --------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-dev-placeholder
OPENAI_API_KEY=sk-dev-placeholder
PROMPT_VERSION=v1
LLM_DAILY_COST_LIMIT_USD=10.0

# ---- Notification bot -----------------------------------------------------
NOTIFY_BOT_TOKEN=000000:dev-placeholder
NOTIFY_BOT_ADMIN_CHAT_ID=0

# ---- Security -------------------------------------------------------------
# 64+ byte random string for HS256 JWTs.
JWT_SECRET=replace-with-32-byte-secret

# ---- Observability --------------------------------------------------------
# SENTRY_DSN is optional in dev — leave empty to disable.
SENTRY_DSN=
LOG_LEVEL=INFO

# ---- Compose-only knobs ---------------------------------------------------
REDIS_MAXMEMORY=512mb
API_PORT=8000
BACKEND_TAG=develop
