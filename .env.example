# ─────────────────────────────────────────────────────────
# Telegram Lead Aggregator — пример env-файла
# Скопируйте в .env и заполните. .env в git НЕ коммитится.
# Запрос/правки реальных значений — только после явного
# разрешения Максима.
# ─────────────────────────────────────────────────────────

# ─── Telegram (FEATURE-01) ───────────────────────────────
# https://my.telegram.org → API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+70000000000
# Ключ AES-256 для шифрования session-файла на диске (32 байта, base64)
TELETHON_SESSION_KEY=
# Путь к зашифрованному session-файлу (mount volume на VPS)
TELETHON_SESSION_PATH=/var/lib/telegram-aggregator/sessions/primary.session.enc

# ─── PostgreSQL ──────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=tlg_agg
POSTGRES_PASSWORD=
POSTGRES_DB=tlg_agg
DATABASE_URL=postgresql+asyncpg://tlg_agg:@postgres:5432/tlg_agg

# ─── Redis (очередь + кэш) ───────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── LLM ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Версия промптов (из backend/prompts/vN/)
PROMPT_VERSION=v1
# Дневной лимит расходов на LLM (USD). При превышении — отключение low-priority источников.
LLM_DAILY_COST_LIMIT_USD=5.0

# ─── Aiogram notify bot (FEATURE-08) ─────────────────────
NOTIFY_BOT_TOKEN=
# Chat ID Максима (числовой), куда слать Hot-уведомления
NOTIFY_BOT_ADMIN_CHAT_ID=
# Тихие часы (локальная TZ ниже). Формат HH:MM.
QUIET_HOURS_START=23:00
QUIET_HOURS_END=08:00
TIMEZONE=Asia/Yekaterinburg

# ─── Admin API / Frontend auth ───────────────────────────
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
# Публичный URL API (для frontend rewrites())
API_URL=http://localhost:8000

# ─── Observability ───────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO
ENVIRONMENT=local
# Prometheus endpoint path
METRICS_PATH=/metrics

# ─── Frontend (Next.js public) ───────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_APP_ENV=local

# ─── Infra / deploy ──────────────────────────────────────
# Тег образа backend (sha-xxxx), подставляется из CI
BACKEND_IMAGE_TAG=dev
# Путь для бэкапов БД на VPS
BACKUP_DIR=/var/backups/tlg-aggregator
